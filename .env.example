# =========================================================
# Receipto - environment configuration template
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# =========================================================

# ---- Messaging: Telegram ----
TELEGRAM_BOT_TOKEN=changeme_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=changeme_random_webhook_secret
TELEGRAM_MODE=polling            # polling | webhook
TELEGRAM_WEBHOOK_URL=            # required only if TELEGRAM_MODE=webhook

# ---- Messaging: WhatsApp (optional extension) ----
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ---- OCR provider ----
# tesseract (default, free/local) | google_vision | mock (offline demo/testing)
OCR_PROVIDER=tesseract
GOOGLE_VISION_API_KEY=

# ---- LLM provider (structured extraction, categorization, summaries) ----
# anthropic | openai | mock (offline demo/testing, no API key needed)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=changeme_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Google Sheets ----
GOOGLE_SHEETS_SPREADSHEET_ID=changeme_spreadsheet_id
GOOGLE_SHEETS_TAB_NAME=Expenses
# Path to a service account JSON key file (never commit this file)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# ---- Storage ----
RECEIPT_STORAGE_DIR=./data/receipts_tmp
RECEIPT_RETENTION_HOURS=24

# ---- App / security ----
APP_ENV=development               # development | production
LOG_LEVEL=INFO
DEFAULT_USER_TIMEZONE=Asia/Kolkata
DEFAULT_CURRENCY=INR

# ---- MCP server ----
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8765
